{
  "report_prefix": {
    "description": "告状消息的前缀文本",
    "type": "string",
    "default": "【🤖 机器人告状】"
  },
  "message_type_mode": {
    "description": "消息类型配置模式",
    "type": "string",
    "options": ["auto", "custom"],
    "default": "auto",
    "hint": "auto: 自动从当前会话推断消息类型（可能不准确）；custom: 手动指定消息类型"
  },
  "custom_message_type": {
    "description": "自定义消息类型",
    "type": "string",
    "default": "FriendMessage",
    "hint": "仅在'消息类型配置模式'为custom时生效。常见值：FriendMessage(私聊), GroupMessage(群聊)",
    "options": ["FriendMessage", "GroupMessage", "DirectMessage", "PrivateMessage"]
  }
}
